#!/bin/sh
# Blocks AI tool attributions from landing in commit history.
# Covers Claude, ChatGPT, Copilot, Codex, Gemini, Cursor, Windsurf, Aider,
# v0, Devin, Cline, and generic AI bylines.
set -eu
MSG_FILE="$1"

if [ ! -f "$MSG_FILE" ]; then
  exit 0
fi

LOWER_MSG=$(tr '[:upper:]' '[:lower:]' < "$MSG_FILE")

for pat in \
  "co-authored-by:.*claude" \
  "co-authored-by:.*anthropic" \
  "co-authored-by:.*chatgpt" \
  "co-authored-by:.*openai" \
  "co-authored-by:.*copilot" \
  "co-authored-by:.*codex" \
  "co-authored-by:.*gemini" \
  "co-authored-by:.*cursor" \
  "co-authored-by:.*windsurf" \
  "co-authored-by:.*aider" \
  "co-authored-by:.*devin" \
  "co-authored-by:.*cline" \
  "co-authored-by:.*v0\.dev" \
  "co-authored-by:.*noreply@anthropic" \
  "co-authored-by:.*noreply@openai" \
  "generated with.*claude" \
  "generated by.*claude" \
  "generated with.*chatgpt" \
  "generated with.*copilot" \
  "generated with.*cursor" \
  "🤖 generated with" \
  "^ai-assisted:" \
  "^ai generated:" \
  "^assisted-by:.*\(claude\|gpt\|copilot\|cursor\|windsurf\|aider\|gemini\)"; do
  if printf "%s" "$LOWER_MSG" | grep -Eq "$pat"; then
    echo ""
    echo "  commit blocked: AI attribution detected."
    echo "  Remove the Co-Authored-By / AI byline and recommit."
    echo "  Pattern matched: $pat"
    echo ""
    exit 1
  fi
done

exit 0
