#!/bin/sh
# Blocks direct pushes to protected branches (dev, main).
# All changes must go through a feature branch and pull request.
set -eu

PROTECTED="dev main"
REMOTE="$1"
REMOTE_URL="$2"

while read local_ref local_sha remote_ref remote_sha; do
  branch=$(printf "%s" "$remote_ref" | sed 's|refs/heads/||')
  for protected in $PROTECTED; do
    if [ "$branch" = "$protected" ]; then
      echo ""
      echo "  push blocked: direct push to '$branch' is not allowed."
      echo "  Open a PR from your feature branch instead."
      echo ""
      exit 1
    fi
  done
done

exit 0
