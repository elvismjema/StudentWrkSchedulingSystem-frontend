{
  "name": "tutorial-frontend-vue3",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "cross-env APP_ENV=development vite",
    "build": "cross-env APP_ENV=production vite build",
    "preview": "vite preview",
    "bundle": "mv .env dist",
    "test": "cypress run",
    "test:open": "cypress open",
    "cap:build": "cross-env CAPACITOR_BUILD=true APP_ENV=production vite build",
    "cap:sync": "npx cap sync",
    "cap:ios": "npx cap open ios",
    "cap:android": "npx cap open android",
    "cap:run:ios": "npm run cap:build && npx cap sync ios && npx cap open ios",
    "cap:run:android": "npm run cap:build && npx cap sync android && npx cap open android"
  },
  "dependencies": {
    "@capacitor/android": "^7.6.1",
    "@capacitor/core": "^7.6.1",
    "@capacitor/ios": "^7.6.1",
    "@fullcalendar/core": "^6.1.20",
    "@fullcalendar/interaction": "^6.1.20",
    "@fullcalendar/timegrid": "^6.1.20",
    "@fullcalendar/vue3": "^6.1.20",
    "@mdi/font": "^7.0.96",
    "axios": "^1.1.3",
    "dotenv": "^16.0.3",
    "eslint": "^8.28.0",
    "eslint-plugin-vue": "^9.7.0",
    "vite-plugin-vuetify": "^1.0.0",
    "vue": "^3.2.47",
    "vue-router": "^4.1.6",
    "vuetify": "^3.0.1",
    "vuex": "^4.0.2",
    "webfontloader": "^1.6.28"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.6.1",
